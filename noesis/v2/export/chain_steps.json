  },
  {
    "step_id": "C003_S3",
    "chain_id": "C003",
    "step_order": 3,
    "label": "Shannon entropy",
    "content": "H=-Σ p_i log₂ p_i",
    "structure_type": null
  },
  {
    "step_id": "C003_S4",
    "chain_id": "C003",
    "step_order": 4,
    "label": "Landauer principle",
    "content": "kT ln 2 per bit erased",
    "structure_type": null
  },
  {
    "step_id": "C004_S1",
    "chain_id": "C004",
    "step_order": 1,
    "label": "Wave equation",
    "content": "∂²u/∂t²=c²∇²u",
    "structure_type": null
  },
