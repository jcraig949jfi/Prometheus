    "chain_id": "C002",
    "step_order": 4,
    "label": "Hamilton equations",
    "content": "q̇=∂H/∂p, ṗ=-∂H/∂q",
    "structure_type": null
  },
  {
    "step_id": "C003_S1",
    "chain_id": "C003",
    "step_order": 1,
    "label": "Boltzmann entropy",
    "content": "S=k_B ln Ω",
    "structure_type": null
  },
