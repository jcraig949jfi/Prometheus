{
  "experiment": "within_domain_structure",
  "description": "Tests whether TT-Cross finds internal structure within a single domain when split by a known variable. Feature 0 (Megethos) and the split variable are zeroed out so we're testing for residual structure. Compared against random splits of the same domain.",
  "methodology": {
    "scorer": "DistributionalCoupling",
    "max_rank": 15,
    "eps": 0.001,
    "subsample": 2000,
    "null_trials": 10,
    "significance_threshold": "2 sigma above null mean"
  },
  "tests": [
    {
      "test_name": "EC_rank_0_vs_1",
      "domain": "elliptic_curves",
      "split_key": "rank",
      "split_values": [
        0,
        1
      ],
      "description": "EC split by rank: does TT find structure between rank-0 and rank-1 beyond conductor distribution?",
      "features_zeroed": {
        "feature_0": 0,
        "split_feature": 1
      },
      "group_a_size": 2000,
      "group_b_size": 2000,
      "split_bond_dim": 4,
      "split_top_svs": [
        43.77587890625,
        9.449113845825195,
        1.6155675649642944,
        6.347589760480332e-07
      ],
      "null_bonds": [
        4,
        4,
        4,
        4,
        4,
        4,
        4,
        4,
        4,
        4
      ],
      "null_mean": 4.0,
      "null_std": 0.5,
      "sigma_separation": 0.0,
      "verdict": "NO_STRUCTURE",
      "wall_time_seconds": 0.64
    },
    {
      "test_name": "EC_torsion_1_vs_2",
      "domain": "elliptic_curves",
      "split_key": "torsion",
      "split_values": [
        1,
        2
      ],
